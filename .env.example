# OpenSwarm Trading Desk environment

# Required: choose a model provider and set the matching key.
OPENAI_API_KEY=
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Model routing.
# Portfolio Manager / orchestrator:
ORCHESTRATOR_MODEL=litellm/openrouter/openrouter/fusion

# All six trading specialists:
SPECIALIST_MODEL=litellm/openrouter/deepseek/deepseek-v4-flash

# Optional fallback if role-specific models are omitted.
DEFAULT_MODEL=

# VPS/API service settings.
OPENSWARM_HOST=0.0.0.0
OPENSWARM_PORT=18080
OPENSWARM_HOST_PORT=18080
OPENSWARM_SERVICE_ROLE=analysis_only
OPENSWARM_LOGS_DIR=activity-logs
OPENSWARM_ALLOWED_LOCAL_FILE_DIRS=./uploads

# Required for any VPS-exposed API. Without this, the FastAPI integration disables auth.
APP_TOKEN=

# Optional Telegram bot sidecar.
# Use a dedicated Telegram bot token. Do not reuse a token that is already polled
# by another service.
OPENSWARM_TELEGRAM_BOT_TOKEN=
OPENSWARM_TELEGRAM_ALLOWED_CHAT_IDS=
OPENSWARM_TELEGRAM_RECIPIENT_AGENT=Portfolio Manager
OPENSWARM_TELEGRAM_DROP_PENDING_UPDATES=1

# Optional Composio integration support.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=
